# Dependencies — reinstalled automatically via "npm install"
node_modules/
/.pnp
.pnp.js

# Next.js build output — generated when you run "npm run build"
/.next/
/out/

# Environment variables — may contain secrets, never upload these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / IDE folders
.vscode/
.idea/

# TypeScript cache
*.tsbuildinfo
next-env.d.ts
